# Production environment template — copy to /opt/saziqo-platform/current/.env.production
# and replace every CHANGE_ME / placeholder before bringing the stack up.
#
#   cp infra/.env.production.template /opt/saziqo-platform/current/.env.production
#   chmod 600 /opt/saziqo-platform/current/.env.production
#   chown deploy:deploy /opt/saziqo-platform/current/.env.production
#
# This file is NEVER committed with real secrets. Generate fresh secrets per
# deployment — do not reuse staging or dev values.

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT_API=3001
PORT_WEB=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Hostname `postgres` matches the service name in docker-compose.prod.yml.
POSTGRES_USER=saziqo
POSTGRES_DB=saziqo
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://saziqo:CHANGE_ME@postgres:5432/saziqo

# ─── Redis ────────────────────────────────────────────────────────────────────
# Production Redis MUST run with `--requirepass`. The same password appears
# inline in REDIS_URL because the BullMQ / ioredis clients parse it from there.
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379

# ─── Meilisearch ──────────────────────────────────────────────────────────────
# Required by the API config schema. Generate the master key with:
#   openssl rand -hex 32
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=CHANGE_ME_openssl_rand_hex_32

# ─── Auth — JWT (generate each with: openssl rand -hex 32) ───────────────────
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Auth — OTP (generate with: openssl rand -hex 32) ────────────────────────
# SECURITY: salt for sha256(code + phone + OTP_SALT). Rotating this invalidates
# all in-flight OTP attempts; rotate only during a maintenance window.
OTP_SALT=CHANGE_ME_openssl_rand_hex_32

# ─── Auth — Super Admin ───────────────────────────────────────────────────────
# Iranian E.164: must match /^\+989\d{9}$/. Seeded by BootstrapService at boot.
SUPER_ADMIN_PHONE=+989XXXXXXXXX

# ─── Email Provider (real SMTP deferred to v1.5) ──────────────────────────────
EMAIL_PROVIDER=console

# ─── SMS Provider (Kavenegar) ─────────────────────────────────────────────────
SMS_PROVIDER=kavenegar
KAVENEGAR_API_KEY=CHANGE_ME
KAVENEGAR_SENDER_LINE=CHANGE_ME

# ─── Payments (ZarinPal) ──────────────────────────────────────────────────────
PAYMENT_PROVIDER=zarinpal
ZARINPAL_MERCHANT_ID=CHANGE_ME_uuid_from_zarinpal
ZARINPAL_SANDBOX=false
ZARINPAL_CALLBACK_URL=https://app.saziqo.ir/api/v1/payments/callback

# ─── File Storage ─────────────────────────────────────────────────────────────
# Container path. Bind-mounted from /opt/saziqo-platform/shared/uploads on the
# host so backups and DR are filesystem-level.
FILE_STORAGE_ROOT=/var/saziqo-platform/files
MAX_UPLOAD_SIZE_MB=10

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allow-list. Production only ever serves from the apex.
CORS_ALLOWED_ORIGINS=https://app.saziqo.ir

# ─── Maintenance Mode ─────────────────────────────────────────────────────────
# Read by the API at request time; flips on a global 503 banner without a
# restart. Wired up in a future phase — present here for forward-compat.
MAINTENANCE_MODE=false

# ─── Logging ──────────────────────────────────────────────────────────────────
# pino-http honors LOG_LEVEL. LOG_FILE points at the bind-mounted host path
# (mounted at /var/log/saziqo-api inside the api container).
LOG_LEVEL=info
LOG_FILE=/var/log/saziqo-api/api.log

# ─── Feature Modules ──────────────────────────────────────────────────────────
# Reference/example module — must be off in production.
ENABLE_EXAMPLE_MODULE=false

# ─── Frontend (NEXT_PUBLIC_*) — inlined into the client bundle at build time ──
# Changing this requires rebuilding the web image. Build script reads it as
# a build arg in docker-compose.prod.yml.
NEXT_PUBLIC_API_BASE_URL=https://app.saziqo.ir/api/v1
