{
  "name": "@saziqo/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist .tsbuildinfo",
    "test": "dotenv -e ../../.env -- jest --runInBand",
    "test:watch": "dotenv -e ../../.env -- jest --watch --runInBand",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate-dev": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate-deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:migrate-reset": "dotenv -e ../../.env -- prisma migrate reset",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:push": "dotenv -e ../../.env -- prisma db push"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.7.0",
    "@saziqo/persian-utils": "workspace:*",
    "@types/cookie-parser": "^1.4.10",
    "cookie-parser": "^1.4.7",
    "file-type": "16.5.4",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "jose": "^5.10.0",
    "mime-types": "^3.0.2",
    "ms": "^2.1.3",
    "multer": "^2.0.2",
    "nestjs-pino": "^4.4.0",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^11.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@saziqo/config": "workspace:*",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/mime-types": "^3.0.1",
    "@types/ms": "^2.1.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.17.57",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "dotenv-cli": "^8.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
