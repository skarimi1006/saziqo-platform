// CLAUDE: This is the canonical core schema. Modules add their own
// schema files later via Prisma multi-file schemas. Core tables here
// are owned by the system, never by a business module. Migrations are
// append-only — never edit a migration that has been applied.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // CLAUDE: S4 read-replica plumbing. For v1 there is one URL.
  // To enable a read replica later, set DATABASE_READ_URL in env and
  // construct a separate PrismaClient inside PrismaService for reads.
}

// ─── Auth & Users ────────────────────────────────────────────────────

model User {
  id                 BigInt     @id @default(autoincrement())
  phone              String     @unique @db.VarChar(15)
  phoneVerifiedAt    DateTime?
  firstName          String?    @db.VarChar(80)
  lastName           String?    @db.VarChar(120)
  nationalId         String?    @unique @db.VarChar(10)
  email              String?    @unique @db.VarChar(255)
  emailVerifiedAt    DateTime?
  profileCompletedAt DateTime?
  status             UserStatus @default(PENDING_PROFILE)
  totpSecret         String?    @db.VarChar(64)
  totpEnabledAt      DateTime?
  betaFlags          String[]   @default([])
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  sessions        Session[]
  userRoles       UserRole[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  wallet          Wallet?
  files           File[]
  ledgerEntries   LedgerEntry[]
  payoutRequests  PayoutRequest[] @relation("PayoutRequester")
  reviewedPayouts   PayoutRequest[] @relation("PayoutReviewer")
  payments          Payment[]
  requestedRefunds  Refund[]        @relation("RefundRequester")

  // Agents module back-relations (module owns the child tables; FKs land
  // in apps/api/src/modules/agents/ Phase 1A migration).
  agentsListings    agents_listing[]
  agentsCartItems   agents_cart_item[]
  agentsPurchases   agents_purchase[]
  agentsUserRuns    agents_user_runs[]
  agentsRunEvents   agents_run_event[]
  agentsReviews     agents_review[]

  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

enum UserStatus {
  PENDING_PROFILE
  ACTIVE
  SUSPENDED
  DELETED
}

model Session {
  id               BigInt    @id @default(autoincrement())
  userId           BigInt
  refreshTokenHash String    @unique @db.VarChar(128)
  userAgent        String?   @db.VarChar(512)
  ipAddress        String?   @db.VarChar(45)
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// SECURITY: An ImpersonationSession captures a single audit-tracked
// admin-impersonates-user session (S3). Tokens issued for this session
// carry an `imp` JWT claim, and the JwtAuthGuard rejects every request
// once `endedAt` is set. The row is permanent; ending an impersonation
// only stamps `endedAt`, never deletes — operational accountability.
model ImpersonationSession {
  id            BigInt    @id @default(autoincrement())
  actorUserId   BigInt
  targetUserId  BigInt
  sessionId     BigInt?
  reason        String    @db.VarChar(500)
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  revokedReason String?   @db.VarChar(500)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([startedAt])
  @@map("impersonation_sessions")
}

// ─── RBAC ────────────────────────────────────────────────────────────

model Role {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  persianName String   @db.VarChar(100)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id          BigInt   @id @default(autoincrement())
  // SECURITY: Permission codes follow strict format module:action:resource
  // (e.g. users:read:profile, ledger:approve:payout). Validated at seed time.
  code        String   @unique @db.VarChar(120)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       BigInt
  permissionId BigInt
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    BigInt
  roleId    BigInt
  // CLAUDE: scope is an optional JSON object for scoped permissions
  // (e.g. { ownership: "any" } vs { ownership: "own" }). Null = no scope.
  scope     Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

// ─── Audit (append-only) ─────────────────────────────────────────────

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  // CLAUDE: actorUserId is nullable for system-generated audit entries
  // (e.g. cron jobs) and to retain history after a user is hard-deleted.
  actorUserId BigInt?
  action      String   @db.VarChar(100)
  resource    String   @db.VarChar(100)
  resourceId  String?  @db.VarChar(64)
  // SECURITY: payloadHash (sha256) records the inputs without storing
  // potentially-sensitive payload values directly.
  payloadHash String   @db.VarChar(64)
  // Denormalized from payload for efficient admin-viewer filtering.
  failed      Boolean  @default(false)
  ipAddress   String?  @db.VarChar(45)
  userAgent   String?  @db.VarChar(512)
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Notifications ───────────────────────────────────────────────────

model Notification {
  id        BigInt              @id @default(autoincrement())
  userId    BigInt
  channel   NotificationChannel
  type      String              @db.VarChar(100)
  payload   Json
  readAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
  @@map("notifications")
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

// ─── Settings ────────────────────────────────────────────────────────

model Setting {
  id        BigInt       @id @default(autoincrement())
  scope     SettingScope
  // CLAUDE: scopeId is the ID of the scope owner — userId for USER scope,
  // moduleName-derived id for MODULE scope, null for GLOBAL scope.
  scopeId   BigInt?
  key       String       @db.VarChar(120)
  value     Json
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([scope, scopeId, key])
  @@map("settings")
}

enum SettingScope {
  GLOBAL
  USER
  MODULE
}

// ─── Ledger (append-only) ────────────────────────────────────────────

model LedgerEntry {
  id          BigInt     @id @default(autoincrement())
  userId      BigInt?
  walletId    BigInt?
  kind        LedgerKind
  // SECURITY: amount is BigInt (toman) — integer only, no floats. Always
  // positive; direction is encoded by `kind` (DEBIT vs CREDIT).
  amount      BigInt
  currency    String     @default("IRT") @db.VarChar(3)
  reference   String?    @db.VarChar(120)
  description String?    @db.VarChar(500)
  metadata    Json?
  createdAt   DateTime   @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  wallet Wallet? @relation(fields: [walletId], references: [id])

  @@index([userId])
  @@index([walletId])
  @@index([reference])
  @@index([createdAt])
  @@map("ledger_entries")
}

enum LedgerKind {
  DEBIT
  CREDIT
}

model Wallet {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @unique
  // SECURITY: balance must equal sum of ledger entries for this wallet.
  // Reconciliation job (Phase 9F) detects drift.
  balance   BigInt   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  ledgerEntries  LedgerEntry[]
  payoutRequests PayoutRequest[]

  @@map("wallets")
}

// ─── Files ───────────────────────────────────────────────────────────

model File {
  id           BigInt    @id @default(autoincrement())
  ownerUserId  BigInt
  path         String    @db.VarChar(512)
  originalName String    @db.VarChar(255)
  mimeType     String    @db.VarChar(120)
  size         BigInt
  // SECURITY: sha256 deduplicates uploads and lets us detect tampering.
  sha256       String    @unique @db.VarChar(64)
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  owner User @relation(fields: [ownerUserId], references: [id])

  // Agents module back-relations
  agentsListingsAsBundle agents_listing[]    @relation("AgentsListingBundle")
  agentsScreenshots      agents_screenshot[]

  @@index([ownerUserId])
  @@index([deletedAt])
  @@map("files")
}

// ─── OTP attempts (append-only) ──────────────────────────────────────

model OtpAttempt {
  id         BigInt    @id @default(autoincrement())
  phone      String    @db.VarChar(15)
  // SECURITY: codeHash is sha256(secret + code); never store the OTP itself.
  codeHash   String    @db.VarChar(128)
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, createdAt])
  @@index([expiresAt])
  @@map("otp_attempts")
}

// ─── Payouts ─────────────────────────────────────────────────────────

model PayoutRequest {
  id               BigInt       @id @default(autoincrement())
  userId           BigInt
  walletId         BigInt
  amount           BigInt
  bankAccount      String       @db.VarChar(34)
  accountHolder    String       @db.VarChar(200)
  status           PayoutStatus @default(PENDING)
  submittedAt      DateTime     @default(now())
  reviewedByUserId BigInt?
  reviewedAt       DateTime?
  rejectionReason  String?      @db.VarChar(500)
  paidAt           DateTime?
  paymentReference String?      @db.VarChar(120)

  user     User   @relation("PayoutRequester", fields: [userId], references: [id])
  wallet   Wallet @relation(fields: [walletId], references: [id])
  reviewer User?  @relation("PayoutReviewer", fields: [reviewedByUserId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
  @@map("payout_requests")
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  CANCELLED
}

// ─── Payments ────────────────────────────────────────────────────────

model Payment {
  id                BigInt        @id @default(autoincrement())
  userId            BigInt
  amount            BigInt
  purpose           String        @db.VarChar(50)
  description       String        @db.VarChar(500)
  status            PaymentStatus @default(PENDING)
  providerName      String        @db.VarChar(40)
  providerReference String?       @db.VarChar(120)
  referenceCode     String?       @db.VarChar(120)
  cardPanMasked     String?       @db.VarChar(20)
  metadata          Json
  initiatedAt       DateTime      @default(now())
  completedAt       DateTime?
  failureReason     String?       @db.VarChar(500)

  user    User     @relation(fields: [userId], references: [id])
  refunds Refund[]

  // Agents module back-relation — populated when payments turn on for
  // agents_purchase rows (locked-decision: schema is payment-ready, but
  // the agents module creates COMPLETED purchases without a Payment row
  // until the system flips ZarinPal live).
  agentsPurchases agents_purchase[]

  @@index([userId])
  @@index([status])
  @@index([providerReference])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

// ─── Refunds ─────────────────────────────────────────────────────────

model Refund {
  id                BigInt       @id @default(autoincrement())
  paymentId         BigInt
  amount            BigInt
  reason            String       @db.VarChar(500)
  status            RefundStatus @default(PENDING_MANUAL)
  requestedByUserId BigInt
  requestedAt       DateTime     @default(now())
  completedAt       DateTime?
  bankReference     String?      @db.VarChar(120)

  payment   Payment @relation(fields: [paymentId], references: [id])
  requester User    @relation("RefundRequester", fields: [requestedByUserId], references: [id])

  @@index([paymentId])
  @@index([status])
  @@map("refunds")
}

enum RefundStatus {
  PENDING_MANUAL
  COMPLETED
}

// ─── Module Registry ─────────────────────────────────────────────────

// CLAUDE: Tracks which platform modules have completed their first-boot
// onInstall hook. The Phase-11B module loader inserts a row the first time
// it sees a module name; on subsequent boots the row's presence short-
// circuits onInstall so it never runs twice. `version` records the version
// that performed the install — modules can compare it to their current
// version to decide whether a re-install/migration is needed.
model ModuleInstall {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique @db.VarChar(60)
  version     String   @db.VarChar(20)
  installedAt DateTime @default(now())

  @@map("modules_installed")
}

// ─── Agents Module ───────────────────────────────────────────────────
// CLAUDE: All `agents_*` tables are owned by apps/api/src/modules/agents.
// Schema appended here because Prisma uses a single schema file for the
// monorepo. Module rules still apply: no other module touches these tables;
// the agents module never reaches into another module's tables. Append-only
// trigger on agents_run_event is added in the agents_append_only_triggers
// migration, not declarable in Prisma DSL.

model agents_category {
  id         BigInt   @id @default(autoincrement())
  slug       String   @unique @db.VarChar(80)
  nameFa     String   @db.VarChar(100)
  iconKey    String   @db.VarChar(40)
  colorToken String   @db.VarChar(20)
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  listings agents_listing[]

  @@index([order])
  @@index([isActive])
}

model agents_listing {
  id                      BigInt    @id @default(autoincrement())
  slug                    String    @unique @db.VarChar(120)
  titleFa                 String    @db.VarChar(200)
  shortDescFa             String    @db.VarChar(300)
  longDescFaMd            String
  installInstructionsFaMd String?
  categoryId              BigInt
  makerUserId             BigInt
  pricingType             AgentsPricingType
  oneTimePriceToman       BigInt?
  status                  AgentsListingStatus @default(DRAFT)
  rejectionReason         String?   @db.VarChar(500)
  suspensionReason        String?   @db.VarChar(500)
  isFeatured              Boolean   @default(false)
  featuredOrder           Int?
  bundleFileId            BigInt?
  // SECURITY: apiKeyHash is sha256 of the per-listing run-consume API key.
  // The plaintext key is returned exactly once on rotation (Phase 4E) and
  // never persisted. apiKeyPreview holds the last 8 chars for UI only.
  apiKeyHash              String?   @db.VarChar(64)
  apiKeyPreview           String?   @db.VarChar(20)
  // Denormalized counters; kept in sync from purchase / run-consume paths.
  totalUsers              BigInt    @default(0)
  totalRuns               BigInt    @default(0)
  viewCount               BigInt    @default(0)
  ratingAverage           Decimal?  @db.Decimal(3, 2)
  ratingCount             BigInt    @default(0)
  // Postgres FTS column populated by trigger added in Phase 1E migration.
  searchVector            Unsupported("tsvector")?
  publishedAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?

  category    agents_category    @relation(fields: [categoryId], references: [id])
  maker       User               @relation(fields: [makerUserId], references: [id])
  bundleFile  File?              @relation("AgentsListingBundle", fields: [bundleFileId], references: [id])
  screenshots agents_screenshot[]
  runPacks    agents_run_pack[]
  cartItems   agents_cart_item[]
  purchases   agents_purchase[]
  userRuns    agents_user_runs[]
  runEvents   agents_run_event[]
  reviews     agents_review[]

  @@index([status, publishedAt])
  @@index([categoryId, status])
  @@index([makerUserId])
  @@index([isFeatured, featuredOrder])
  @@index([deletedAt])
}

enum AgentsPricingType {
  FREE
  ONE_TIME
  PER_RUN
}

enum AgentsListingStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  SUSPENDED
}

model agents_screenshot {
  id        BigInt  @id @default(autoincrement())
  listingId BigInt
  fileId    BigInt
  order     Int     @default(0)
  altTextFa String? @db.VarChar(200)

  listing agents_listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  file    File           @relation(fields: [fileId], references: [id])

  @@index([listingId, order])
}

model agents_run_pack {
  // Run-pack definitions on a PER_RUN listing. 1–5 packs per listing.
  id         BigInt   @id @default(autoincrement())
  listingId  BigInt
  nameFa     String   @db.VarChar(80)
  runs       BigInt
  priceToman BigInt
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  listing   agents_listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  cartItems agents_cart_item[]
  purchases agents_purchase[]

  @@index([listingId, order])
}

model agents_cart_item {
  id        BigInt   @id @default(autoincrement())
  // userId is nullable so a guest cart item can be persisted post-merge
  // even if the originating user row was removed; the live merge flow
  // (Phase 3A) writes userId on every row.
  userId    BigInt?
  listingId BigInt
  runPackId BigInt?
  addedAt   DateTime @default(now())

  user    User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  listing agents_listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  runPack agents_run_pack? @relation(fields: [runPackId], references: [id])

  @@unique([userId, listingId, runPackId])
  @@index([userId, addedAt])
}

model agents_purchase {
  // SECURITY: append-only by convention except for refund-status flips —
  // see CLAUDE.md "Append-only enforcement". No DB trigger here; the
  // refund path is the only mutation surface and is audited via
  // AGENTS_PURCHASE_REFUNDED.
  id                BigInt   @id @default(autoincrement())
  userId            BigInt
  listingId         BigInt
  pricingTypeAtSale AgentsPricingType
  runPackId         BigInt?
  runsGranted       BigInt   @default(0)
  amountToman       BigInt
  commissionToman   BigInt
  makerEarnedToman  BigInt
  systemPaymentId   BigInt?
  status            AgentsPurchaseStatus @default(COMPLETED)
  refundReason      String?  @db.VarChar(500)
  createdAt         DateTime @default(now())
  refundedAt        DateTime?

  user          User             @relation(fields: [userId], references: [id])
  listing       agents_listing   @relation(fields: [listingId], references: [id])
  runPack       agents_run_pack? @relation(fields: [runPackId], references: [id])
  systemPayment Payment?         @relation(fields: [systemPaymentId], references: [id])

  @@index([userId, createdAt])
  @@index([listingId, createdAt])
  @@index([status])
}

enum AgentsPurchaseStatus {
  COMPLETED
  REFUNDED
}

model agents_user_runs {
  // Per-user, per-listing remaining run counter (PER_RUN pricing). Cumulative.
  id             BigInt    @id @default(autoincrement())
  userId         BigInt
  listingId      BigInt
  remainingRuns  BigInt    @default(0)
  totalGranted   BigInt    @default(0)
  totalConsumed  BigInt    @default(0)
  lastConsumedAt DateTime?

  user    User           @relation(fields: [userId], references: [id])
  listing agents_listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model agents_run_event {
  // SECURITY: append-only — DB triggers in agents_append_only_triggers
  // migration block UPDATE/DELETE on this table for analytics +
  // dispute-resolution integrity.
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  listingId BigInt
  outcome   AgentsRunOutcome
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.VarChar(255)
  createdAt DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id])
  listing agents_listing @relation(fields: [listingId], references: [id])

  @@index([userId, listingId, createdAt])
  @@index([listingId, createdAt])
}

enum AgentsRunOutcome {
  CONSUMED
  REFUSED_INSUFFICIENT
  REFUSED_INVALID_KEY
}

model agents_review {
  id           BigInt   @id @default(autoincrement())
  listingId    BigInt
  authorUserId BigInt
  rating       Int
  bodyFa       String?  @db.VarChar(2000)
  isHidden     Boolean  @default(false)
  hiddenReason String?  @db.VarChar(500)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listing agents_listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  author  User           @relation(fields: [authorUserId], references: [id])

  @@unique([listingId, authorUserId])
  @@index([listingId, createdAt])
  @@index([authorUserId])
}

model agents_settings {
  // Singleton row (id = 1). Admin-editable. Bootstrap upserts in Phase 1C.
  id                        BigInt   @id @default(1)
  commissionPercent         Int      @default(20)
  heroTitleFa               String   @default("عامل‌های فارسی، به دست سازندگان ایرانی.") @db.VarChar(200)
  heroSubtitleFa            String   @default("از پنل کشف عامل‌های آماده، تا استودیوی انتشار و کسب درآمد — همه در یک جا، با پرداخت ریالی، روی سرور ایران.") @db.VarChar(500)
  showFeaturedSection       Boolean  @default(true)
  showCategoriesSection     Boolean  @default(true)
  showBestSellersSection    Boolean  @default(true)
  showNewReleasesSection    Boolean  @default(true)
  showRecentActivitySection Boolean  @default(true)
  featuredItemCount         Int      @default(6)
  bestSellersItemCount      Int      @default(8)
  newReleasesItemCount      Int      @default(8)
  updatedAt                 DateTime @updatedAt
  updatedByUserId           BigInt?
}
