# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT_API=3001
PORT_WEB=3000

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=saziqo
POSTGRES_DB=saziqo
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://saziqo:change_me_in_production@localhost:5432/saziqo

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Meilisearch ──────────────────────────────────────────────────────────────
MEILI_MASTER_KEY=change_me_32_chars_minimum_key
MEILI_URL=http://localhost:7700

# ─── Auth — JWT (generate with: openssl rand -hex 32) ─────────────────────────
JWT_SECRET=replace_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=replace_with_another_openssl_rand_hex_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Auth — Super Admin ────────────────────────────────────────────────────────
# Iranian E.164 format: +989XXXXXXXXX
SUPER_ADMIN_PHONE=+989XXXXXXXXX

# ─── SMS Provider (Kavenegar) ─────────────────────────────────────────────────
SMS_PROVIDER=console
KAVENEGAR_API_KEY=your_kavenegar_api_key_here
KAVENEGAR_SENDER_LINE=your_sender_line_here

# ─── Payments (ZarinPal) ──────────────────────────────────────────────────────
ZARINPAL_MERCHANT_ID=your_zarinpal_merchant_id_here
ZARINPAL_SANDBOX=true

# ─── File Storage ─────────────────────────────────────────────────────────────
FILE_STORAGE_PATH=/var/saziqo-platform/files
FILE_MAX_SIZE_MB=10

# ─── Error Tracking ───────────────────────────────────────────────────────────
# GLITCHTIP_DSN=https://...@glitchtip.yourdomain.com/1
