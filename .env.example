# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT_API=3001
PORT_WEB=3000

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=saziqo
POSTGRES_DB=saziqo
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://saziqo:change_me_in_production@localhost:5432/saziqo

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Meilisearch ──────────────────────────────────────────────────────────────
MEILI_MASTER_KEY=change_me_32_chars_minimum_key
MEILI_URL=http://localhost:7700

# ─── Auth — JWT (generate with: openssl rand -hex 32) ─────────────────────────
JWT_SECRET=replace_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=replace_with_another_openssl_rand_hex_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Auth — OTP (generate with: openssl rand -hex 32) ────────────────────────
OTP_SALT=replace_with_openssl_rand_hex_32

# ─── Auth — Super Admin ────────────────────────────────────────────────────────
# Iranian E.164 format: +989XXXXXXXXX (must be 13 chars, digits only after +989)
SUPER_ADMIN_PHONE=+989123456789

# ─── Email Provider (real SMTP deferred to v1.5 — smtp adapter throws at startup) ─
EMAIL_PROVIDER=console

# ─── SMS Provider (Kavenegar) ─────────────────────────────────────────────────
SMS_PROVIDER=console
KAVENEGAR_API_KEY=your_kavenegar_api_key_here
KAVENEGAR_SENDER_LINE=your_sender_line_here

# ─── Payments (ZarinPal) ──────────────────────────────────────────────────────
# Default to console adapter for local dev; switch to "zarinpal" once a real
# merchant_id is provisioned. The console adapter simulates payments via a
# Redis flag, so no external credentials are required for development or CI.
PAYMENT_PROVIDER=console
ZARINPAL_MERCHANT_ID=00000000-0000-0000-0000-000000000000
ZARINPAL_CALLBACK_URL=https://app.saziqo.ir/api/v1/payments/callback
ZARINPAL_SANDBOX=true

# ─── File Storage ─────────────────────────────────────────────────────────────
# Absolute path in production; relative ./tmp/saziqo-files for local dev (not
# committed — listed in .gitignore via the tmp/ rule). The API ensures the
# directory exists at boot.
FILE_STORAGE_ROOT=./tmp/saziqo-files
MAX_UPLOAD_SIZE_MB=10

# ─── CORS — comma-separated list of allowed origins (no spaces required) ──────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Feature Modules ─────────────────────────────────────────────────────────
# Reference/example module — ships dark in production. Set to true to exercise
# the module contract in dev; remove or set to false before going live.
ENABLE_EXAMPLE_MODULE=true

# ─── Error Tracking ───────────────────────────────────────────────────────────
# GLITCHTIP_DSN=https://...@glitchtip.yourdomain.com/1
