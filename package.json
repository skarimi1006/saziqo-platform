{
  "name": "saziqo-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@saziqo/config": "workspace:*",
    "eslint": "^9.26.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "turbo": "^2.9.6",
    "typescript": "^5.8.3"
  }
}
